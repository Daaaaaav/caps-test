APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# SYSTEM_MODE controls login security behavior:
# development = OTP OFF and CAPTCHA OFF
# deployment  = OTP ON and CAPTCHA ON
SYSTEM_MODE=development

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=krbs
DB_USERNAME=root
DB_PASSWORD=


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Optional: when running with Docker Wazuh profile, keep this default path.
WAZUH_ALERT_LOG_PATH=/var/ossec/logs/alerts/alerts.log

# Optional: host port for Docker MySQL (container still uses 3306 internally).
MYSQL_HOST_PORT=3307

# Optional: host ports for the Wazuh profile. The container still listens on
# 1514/udp and 1515 internally.
WAZUH_AGENT_HOST_PORT=1514
WAZUH_MANAGER_HOST_PORT=1516

# LSTM Service Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Local development  : http://127.0.0.1:8001
# ngrok tunnel       : https://<your-subdomain>.ngrok-free.app
# Docker (internal)  : http://lstm-service:8001
#
# NGROK DEPLOYMENT STEPS:
#   1. Start the FastAPI service (from the project root):
#      python -m uvicorn app.Services.AI.LSTM_Service:app --host 0.0.0.0 --port 8001
#      -- OR double-click app/Services/AI/start_lstm.bat --
#   2. In a second terminal, start an ngrok tunnel:
#      ngrok http 8001
#   3. Copy the https://xxxx.ngrok-free.app URL ngrok prints
#   4. Set LSTM_SERVICE_URL to that URL in your .env
#   5. Optionally restrict CORS by setting ALLOWED_ORIGINS on the Python side:
#      set ALLOWED_ORIGINS=https://your-laravel-ngrok-url.ngrok-free.app
#      python -m uvicorn ...
# ─────────────────────────────────────────────────────────────────────────────
LSTM_SERVICE_URL=http://127.0.0.1:8001
LSTM_SERVICE_TIMEOUT=30

# Docker Configuration (only used when deploying with Docker)
APP_PORT=80

ZOOM_ACCOUNT_ID=xxxxxxxxxxxx
ZOOM_CLIENT_ID=xxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxx

GOOGLE_APPLICATION_CREDENTIALS=storage/app/google/google-service-account.json
GOOGLE_CLIENT_SECRET=storage/app/google/client_secret.json
GOOGLE_TOKEN_PATH=storage/app/google/token.json
GOOGLE_CALENDAR_ID=primary