# Ignore Google OAuth tokens and service account keys
/storage/app/google_tokens/
/storage/app/keys/

# Optional: ignore any JSON credentials in storage just in case
/storage/app/*.json

# Laravel runtime caches (stop tracking view/cache/log files)
/storage/app/*
!/storage/app/.gitignore

/storage/framework/*
!/storage/framework/.gitignore

/storage/logs/*
!/storage/logs/.gitignore

# (optional) compiled cache files
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

