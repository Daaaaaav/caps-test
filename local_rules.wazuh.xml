<!-- Local rules for Laravel receptionist security monitoring -->
<group name="local,laravel,">

  <rule id="100110" level="5">
    <match>LOGIN_FAILED</match>
    <description>Login failure observed</description>
  </rule>

  <rule id="100100" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100110</if_matched_sid>
    <description>Brute force login detected</description>
  </rule>

  <rule id="100101" level="3">
    <match>LOGIN_SUCCESS</match>
    <description>Login success</description>
  </rule>

  <rule id="100120" level="4">
    <match>FORM_SUBMIT</match>
    <description>Receptionist form submission observed</description>
  </rule>

  <rule id="100102" level="9" frequency="10" timeframe="60">
    <if_matched_sid>100120</if_matched_sid>
    <description>Form spam detected</description>
  </rule>

  <rule id="100103" level="12">
    <match>' OR 1=1</match>
    <description>SQL Injection attempt</description>
  </rule>

  <rule id="100104" level="12">
    <regex>XSS_DETECTED|&lt;script&gt;</regex>
    <description>XSS attempt</description>
  </rule>

</group>
